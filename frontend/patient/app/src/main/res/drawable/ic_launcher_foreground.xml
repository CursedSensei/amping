<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="200"
    android:viewportHeight="200">

    <!-- Group applies pivot scaling to fit perfectly inside the 66dp Safe Area -->
    <group
        android:pivotX="100"
        android:pivotY="100"
        android:scaleX="0.72"
        android:scaleY="0.72">

        <!-- Symmetrical Mascot Body (Soft blue sky gradient) -->
        <path
            android:pathData="M 100,25 C 150,23 175,55 175,100 C 175,145 150,175 100,175 C 50,175 25,145 25,100 C 25,55 50,23 100,25 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="0"
                    android:startY="0"
                    android:endX="200"
                    android:endY="200"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#54B3FF" />
                    <item android:offset="1.0" android:color="#429BF4" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Left Vertical White Eye -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M 83,75 C 83,72.2 85.2,70 88,70 C 90.8,70 93,72.2 93,75 L 93,80 C 93,82.8 90.8,85 88,85 C 85.2,85 83,82.8 83,80 Z" />

        <!-- Right Vertical White Eye -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M 107,75 C 107,72.2 109.2,70 112,70 C 114.8,70 117,72.2 117,75 L 117,80 C 117,82.8 114.8,85 112,85 C 109.2,85 107,82.8 107,80 Z" />

        <!-- Surprised Open Mouth (Navy deep shadow) -->
        <path
            android:fillColor="#112335"
            android:pathData="M 100,92 A 14,14 0 1,1 100,120 A 14,14 0 1,1 100,92" />

    </group>
</vector>